<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>全字體可調式問答貪食蛇 - Firebase 雲端資料庫版</title>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Microsoft JhengHei', Arial, sans-serif;
            background: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            margin: 0;
            min-height: 100vh;
        }
        h1 { margin-bottom: 10px; }
        .control-panel {
            background: #34495e;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 15px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 800px;
        }
        .upload-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }
        .btn-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .btn-export {
            background: #2ecc71; color: white; border: none; padding: 8px 16px;
            font-size: 1em; font-weight: bold; border-radius: 6px; cursor: pointer;
            transition: background 0.2s; box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .btn-export:hover { background: #27ae60; }
        .btn-reset {
            background: #e74c3c; color: white; border: none; padding: 8px 16px;
            font-size: 1em; font-weight: bold; border-radius: 6px; cursor: pointer;
            transition: background 0.2s; box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .btn-reset:hover { background: #c0392b; }
        .setting-group {
            display: flex; justify-content: space-around; align-items: center;
            flex-wrap: wrap; margin-top: 15px; background: rgba(0,0,0,0.2);
            padding: 10px; border-radius: 8px; gap: 10px;
        }
        .setting-item { display: flex; align-items: center; gap: 8px; }
        .setting-item label { font-weight: bold; font-size: 0.95em; }
        .file-input { color: #ecf0f1; margin-left: 10px; }
        #gameContainer {
            position: relative; display: flex; flex-direction: column;
            align-items: center; width: 100%;
        }
        #questionBox {
            background: #f1c40f; color: #2c3e50; padding: 20px; border-radius: 8px;
            font-size: 66px; font-weight: bold; width: 100%; max-width: 1200px;
            text-align: center; margin-bottom: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: font-size 0.1s ease;
        }
        #versionTag { font-size: 24px; display: block; color: #7f8c8d; margin-bottom: 5px; font-weight: normal; }
        .canvas-wrapper {
            background: #111; border: 4px solid #3498db; border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); overflow: hidden; display: inline-block;
        }
        canvas { display: block; cursor: crosshair; }
        .score-board {
            display: flex; gap: 40px; font-size: 1.8em; margin-top: 15px;
            font-weight: bold; background: rgba(0,0,0,0.4); padding: 10px 30px; border-radius: 20px;
        }
        #wrongNotice {
            color: #ff4757; font-size: 1.4em; margin-top: 10px;
            font-weight: bold; min-height: 1.5em; transition: all 0.2s;
        }
        #dbStatus { color: #2ecc71; font-weight: bold; font-size: 0.9em; margin-top: 5px;}
    </style>
</head>
<body>

    <h1>🐍 全字體可調式問答貪食蛇 (雲端資料庫版)</h1>
    
    <div class="control-panel">
        <div id="setupBox" class="upload-section">
            <div class="btn-group">
                <button class="btn-export" onclick="exportTemplate()">📥 下載資料庫現有題庫 Excel</button>
                <button class="btn-reset" onclick="resetToDefaultInDB()">🔄 重置雲端資料庫為預設值</button>
            </div>
            <hr style="width: 100%; border: 0; border-top: 1px solid rgba(255,255,255,0.1); margin: 5px 0;">
            <div>
                <span>覆蓋雲端資料庫題目 (`.xlsx`)：</span>
                <input type="file" id="excelFile" class="file-input" accept=".xlsx, .xls" />
                <div id="dbStatus">📡 連線雲端資料庫中...</div>
            </div>
        </div>
        
        <div class="setting-group">
            <div class="setting-item">
                <label for="fontSizeSlider">🔤 全域字體大小:</label>
                <input type="range" id="fontSizeSlider" min="20" max="100" value="66">
                <span id="fontSizeVal">66px</span>
            </div>
            <div class="setting-item">
                <label for="canvasWidthSlider">🖥️ 遊戲畫面寬度:</label>
                <input type="range" id="canvasWidthSlider" min="400" max="1600" step="50" value="1200">
                <span id="canvasWidthVal">1200px</span>
            </div>
        </div>
    </div>

    <div id="gameContainer">
        <div id="questionBox"><span id="versionTag"></span><span id="qText">讀取雲端題庫中...</span></div>
        <div class="canvas-wrapper">
            <canvas id="gameCanvas" width="1200" height="800"></canvas>
        </div>
        <div id="wrongNotice"></div>
        <div class="score-board">
            <div>得分: <span id="score">0</span></div>
            <div>目前關卡: <span id="level">1</span></div>
        </div>
    </div>

    <script>
        // ==========================================
        // 🛠️ 填入您的 Firebase 設定 (請看後續教學步驟)
        // ==========================================
        const firebaseConfig = {
            apiKey: "請更換為您的ApiKey",
            authDomain: "請更換為您的專案ID.firebaseapp.com",
            databaseURL: "https://請更換為您的專案ID-default-rtdb.firebaseio.com/",
            projectId: "請更換為您的專案ID",
            storageBucket: "請更換為您的專案ID.appspot.com",
            messagingSenderId: "請更換",
            appId: "請更換"
        };

        // 初始化 Firebase
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();
        const dbRef = database.ref("snake_questions");

        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const fontSizeSlider = document.getElementById("fontSizeSlider");
        const canvasWidthSlider = document.getElementById("canvasWidthSlider");
        const questionBox = document.getElementById("questionBox");
        const wrongNotice = document.getElementById("wrongNotice");
        const dbStatus = document.getElementById("dbStatus");

        let currentFontSize = 66; 
        let snake = [];
        let snakeLength = 5;
        let speed = 5; 
        let mouseX = 600, mouseY = 400; 
        
        const defaultQuestions = [
            { version: "康軒-5-1", question: "文「 」", A: "載", B: "字", C: "讓", answer: "B" },
            { version: "康軒-5-1", question: "輕「 」", A: "舟", B: "忌", C: "訣", answer: "A" },
            { version: "康軒-5-1", question: "「 」水", A: "練", B: "習", C: "灑", answer: "C" },
            { version: "康軒-5-1", question: "「 」人", A: "載", B: "似", C: "灑", answer: "A" }
        ];

        let questions = []; 
        let currentQuestionIndex = 0;
        let score = 0;
        let gameInterval;
        let foods = []; 
        let isGameOver = false;
        let noticeTimeout;

        // 【核心機制】即時監聽雲端資料庫 (當資料庫有變動時，網頁自動更新且重啟遊戲)
        dbRef.on("value", (snapshot) => {
            const data = snapshot.val();
            if (data) {
                questions = data;
                dbStatus.textContent = `🟢 雲端資料庫連線成功！共有 ${questions.length} 題。`;
            } else {
                // 如果資料庫是空的，自動初始化寫入預設題目
                questions = defaultQuestions;
                dbRef.set(defaultQuestions);
                dbStatus.textContent = "🟡 雲端查無資料，已自動建立預設題目。";
            }
            startGame();
        }, (error) => {
            dbStatus.textContent = "🔴 資料庫連線失敗，請檢查金鑰及規則設定。";
            console.error(error);
        });

        function exportTemplate() {
            if (questions.length === 0) return;
            const worksheet = XLSX.utils.json_to_sheet(questions);
            const workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, "國語題庫");
            XLSX.writeFile(workbook, "雲端資料庫_題庫匯出.xlsx");
        }

        function resetToDefaultInDB() {
            if (confirm("⚠️ 確定要清空雲端資料庫，恢復成最初的內建預設 4 題嗎？")) {
                dbStatus.textContent = "🔄 正在寫入預設題庫...";
                dbRef.set(defaultQuestions).then(() => {
                    alert("✅ 雲端資料庫重置完成！");
                });
            }
        }

        function handleExcelUpload(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(evt) {
                try {
                    const data = evt.target.result;
                    const workbook = XLSX.read(data, { type: 'binary' });
                    const firstSheetName = workbook.SheetNames[0];
                    const worksheet = workbook.Sheets[firstSheetName];
                    const jsonRows = XLSX.utils.sheet_to_json(worksheet);
                    
                    if(jsonRows.length === 0) {
                        alert("❌ 讀取失敗：Excel 內無資料！");
                        return;
                    }

                    const importedQuestions = jsonRows.map((row, index) => {
                        const cleanRow = {};
                        Object.keys(row).forEach(key => {
                            cleanRow[key.toString().toLowerCase().trim()] = row[key];
                        });

                        const v = cleanRow['version'] || cleanRow['版本'] || "未分類";
                        const q = cleanRow['question'] || cleanRow['題目'];
                        const a = cleanRow['optiona'] || cleanRow['a'];
                        const b = cleanRow['optionb'] || cleanRow['b'];
                        const c = cleanRow['optionc'] || cleanRow['c'];
                        const ans = cleanRow['answer'] || cleanRow['答案'];

                        if (!q || !a || !b || !c || !ans) {
                            throw new Error(`第 ${index + 2} 列資料不完整！\n需有 version, question, optionA, optionB, optionC, answer`);
                        }

                        return {
                            version: v.toString().trim(),
                            question: q,
                            A: a, B: b, C: c,
                            answer: ans.toString().trim().toUpperCase()
                        };
                    });
                    
                    // 【寫入雲端資料庫】
                    dbStatus.textContent = "📤 正在同步上傳至雲端資料庫...";
                    dbRef.set(importedQuestions).then(() => {
                        alert(`🎉 成功同步更新雲端資料庫！共 ${importedQuestions.length} 題。`);
                    }).catch(err => {
                        alert("❌ 上傳失敗，請確認 Firebase 安全規則設定是否允許寫入。");
                        console.error(err);
                    });

                } catch (error) {
                    alert(`⚠️ 匯入失敗！錯誤原因：\n${error.message}`);
                }
                e.target.value = "";
            };
            reader.readAsBinaryString(file);
        }

        document.getElementById('excelFile').addEventListener('change', handleExcelUpload);

        fontSizeSlider.addEventListener("input", (e) => {
            currentFontSize = parseInt(e.target.value); 
            document.getElementById("fontSizeVal").textContent = currentFontSize + "px";
            questionBox.style.fontSize = currentFontSize + "px";
        });

        canvasWidthSlider.addEventListener("input", (e) => {
            const width = parseInt(e.target.value);
            const height = Math.round(width * 2 / 3); 
            document.getElementById("canvasWidthVal").textContent = width + "px";
            const oldWidth = canvas.width;
            const oldHeight = canvas.height;
            canvas.width = width;
            canvas.height = height;

            if (foods.length > 0) {
                foods.forEach(food => {
                    food.x = (food.x / oldWidth) * width;
                    food.y = (food.y / oldHeight) * height;
                });
            }
        });

        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            mouseX = e.clientX - rect.left;
            mouseY = e.clientY - rect.top;
        });

        function startGame() {
            if (questions.length === 0) return;
            isGameOver = false;
            score = 0;
            currentQuestionIndex = 0;
            snakeLength = 5; 
            document.getElementById('score').textContent = score;
            wrongNotice.textContent = "";
            
            snake = [];
            for (let i = 0; i < snakeLength; i++) {
                snake.push({ x: canvas.width / 2, y: canvas.height / 2 });
            }

            loadQuestion();
            
            if (gameInterval) clearInterval(gameInterval);
            gameInterval = setInterval(gameLoop, 1000 / 60); 
        }

        function loadQuestion() {
            if (currentQuestionIndex >= questions.length) {
                isGameOver = true;
                clearInterval(gameInterval);
                alert(`🎉 恭喜你順利答完全部題目！\n最終得分: ${score}`);
                startGame();
                return;
            }

            const q = questions[currentQuestionIndex];
            document.getElementById('versionTag').textContent = `📍 範圍：${q.version}`;
            document.getElementById('qText').textContent = `【第 ${currentQuestionIndex+1} 題】${q.question}`;
            document.getElementById('level').textContent = currentQuestionIndex + 1;

            const options = ['A', 'B', 'C'];
            foods = [];

            options.forEach((opt) => {
                let posX, posY, isOverlapping, attempts = 0;
                const minDistance = Math.max(220, currentFontSize * 3.2);

                do {
                    isOverlapping = false;
                    posX = Math.random() * (canvas.width - 350) + 175;
                    posY = Math.random() * (canvas.height - 250) + 125;

                    for (let j = 0; j < foods.length; j++) {
                        let other = foods[j];
                        let dist = Math.sqrt(Math.pow(posX - other.x, 2) + Math.pow(posY - other.y, 2));
                        if (dist < minDistance) { isOverlapping = true; break; }
                    }
                    attempts++;
                    if (attempts > 200) break;
                } while (isOverlapping);

                foods.push({ type: opt, text: q[opt], x: posX, y: posY });
            });
        }

        function gameLoop() {
            if (isGameOver) return;
            updateSnake();
            checkCollisions();
            drawGame();
        }

        function updateSnake() {
            let head = { ...snake[0] };
            let dx = mouseX - head.x; let dy = mouseY - head.y;
            let distance = Math.sqrt(dx * dx + dy * dy);

            if (distance > 5) {
                let angle = Math.atan2(dy, dx);
                head.x += Math.cos(angle) * speed;
                head.y += Math.sin(angle) * speed;
            }

            if (head.x < 0) head.x = canvas.width;
            if (head.x > canvas.width) head.x = 0;
            if (head.y < 0) head.y = canvas.height;
            if (head.y > canvas.height) head.y = 0;

            snake.unshift(head);
            if (snake.length > snakeLength) snake.pop();
        }

        function checkCollisions() {
            let head = snake[0];
            for (let i = 0; i < foods.length; i++) {
                let food = foods[i];
                let dx = head.x - food.x; let dy = head.y - food.y;
                let dist = Math.sqrt(dx * dx + dy * dy);
                const collisionRange = Math.max(35, currentFontSize * 0.7);

                if (dist < 12 + collisionRange) {
                    const currentAnswer = questions[currentQuestionIndex].answer;
                    if (food.type === currentAnswer) {
                        score += 10; snakeLength += 3;
                        document.getElementById('score').textContent = score;
                        currentQuestionIndex++; loadQuestion();
                    } else {
                        score -= 5; snakeLength = Math.max(5, snakeLength - 3);
                        document.getElementById('score').textContent = score;
                        clearTimeout(noticeTimeout);
                        wrongNotice.textContent = `❌ 答錯囉！扣 5 分。本題重新挑戰！`;
                        noticeTimeout = setTimeout(() => { wrongNotice.textContent = ""; }, 2000);
                        loadQuestion();
                    }
                    break;
                }
            }
        }

        function drawGame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            foods.forEach(food => {
                ctx.font = `${currentFontSize}px 'Microsoft JhengHei'`;
                ctx.fillStyle = "#ecf0f1"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
                ctx.fillText(food.text, food.x, food.y);
            });
            snake.forEach((part, index) => {
                ctx.beginPath();
                let radius = index === 0 ? 14 : Math.max(8, 14 - index * 0.2);
                ctx.arc(part.x, part.y, radius, 0, Math.PI * 2);
                ctx.fillStyle = index === 0 ? "#00FF00" : (index % 2 === 0 ? "#27ae60" : "#2ecc71");
                ctx.fill(); ctx.closePath();
            });
        }
    </script>
</body>
</html>
